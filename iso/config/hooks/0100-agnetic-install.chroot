#!/bin/sh
# live-build hook: install Starship OS after base system
set -e

echo "=== Starship OS ISO — Custom Hook ==="

# Install Ollama
curl -fsSL https://ollama.com/install.sh | sh

# Install NATS
NATS_VERSION="2.14.3"
curl -fsSL "https://github.com/nats-io/nats-server/releases/download/v${NATS_VERSION}/nats-server-v${NATS_VERSION}-linux-amd64.tar.gz" | tar xz -C /usr/local/bin --strip-components=1 nats-server-v${NATS_VERSION}-linux-amd64/nats-server

# Create agnetic user
useradd --system --no-create-home --shell /usr/sbin/nologin --comment "Starship OS" agnetic || true
useradd --system --no-create-home --shell /usr/sbin/nologin --comment "NATS" nats || true

# Create directories
mkdir -p /opt/agnetic/{bin,lib/agnetic,venv}
mkdir -p /etc/agnetic/nats
mkdir -p /var/lib/agnetic/{nats,message-history}
mkdir -p /var/log/agnetic

# Create Python venv
python3 -m venv /opt/agnetic/venv
/opt/agnetic/venv/bin/pip install --upgrade pip -q
/opt/agnetic/venv/bin/pip install nats-py aiohttp httpx PyYAML -q

# Set ownership
chown -R agnetic:agnetic /opt/agnetic /etc/agnetic /var/lib/agnetic /var/log/agnetic
chown -R nats:nats /var/lib/agnetic/nats

echo "=== Starship OS ISO — Hook Complete ==="
