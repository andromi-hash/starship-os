[Unit]
Description=Starship OS StarAgent Telemetry Collector
Documentation=https://github.com/andromi-hash/starship-os
After=nats.service
BindsTo=starship-nats.service

[Service]
Type=simple
ExecStart=/home/tech/.cargo/bin/staragent
Restart=always
RestartSec=3
User=tech
Group=tech
Environment=NATS_URL=nats://127.0.0.1:4222

[Install]
WantedBy=multi-user.target
